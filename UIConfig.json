{
  "page": {
    "label": "TRANSLATE.PLUGIN_NAME",
    "icon": "fa-server"
  },
  "sections": [
    {
      "id": "section_server",
      "element": "section",
      "label": "TRANSLATE.SERVER_SECTION",
      "onSave": {
        "type": "controller",
        "endpoint": "music_service/musicserver",
        "method": "saveServerSettings"
      },
      "saveButton": {
        "label": "TRANSLATE.SAVE",
        "data": ["protocol", "host", "port", "apiKey"]
      },
      "content": [
        {
          "id": "protocol",
          "element": "select",
          "label": "TRANSLATE.PROTOCOL",
          "value": { "value": "http", "label": "HTTP" },
          "options": [
            {
              "value": "http",
              "label": "HTTP"
            },
            {
              "value": "https",
              "label": "HTTPS"
            }
          ]
        },
        {
          "id": "host",
          "element": "input",
          "label": "TRANSLATE.HOST",
          "value": "127.0.0.1"
        },
        {
          "id": "port",
          "element": "input",
          "label": "TRANSLATE.PORT",
          "value": "3000"
        },
        {
          "id": "apiKey",
          "element": "input",
          "label": "TRANSLATE.API_KEY",
          "value": ""
        }
      ]
    }
  ]
}
